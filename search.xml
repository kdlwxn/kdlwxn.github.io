      <title>C语言网上商城</title>
      <link href="/2022/11/11/C%E8%AF%AD%E8%A8%80%E7%BD%91%E4%B8%8A%E5%95%86%E5%9F%8E%E9%A1%B9%E7%9B%AE/%E6%BC%94%E7%A4%BA/"/>
      <url>/2022/11/11/C%E8%AF%AD%E8%A8%80%E7%BD%91%E4%B8%8A%E5%95%86%E5%9F%8E%E9%A1%B9%E7%9B%AE/%E6%BC%94%E7%A4%BA/</url>
      
        <content type="html"><![CDATA[<figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">#include &lt;stdio.h&gt;</span><br><span class="line">#include &lt;stdlib.h&gt;</span><br><span class="line">#include &lt;windows.h&gt; </span><br><span class="line">#include &lt;conio.h&gt;</span><br><span class="line"></span><br><span class="line">// project: shopSystem</span><br><span class="line">//date:12/16</span><br><span class="line">//auth:</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">#define ADMINPWD &quot;000000&quot; //管理员密码</span><br><span class="line">#define ADMINACCOUT &quot;admin&quot; //管理员账号</span><br><span class="line">#define FILENAME &quot;D:\\c\\data\\spdata.txt&quot; //文件路径</span><br><span class="line"></span><br><span class="line">//结构体</span><br><span class="line">struct Product </span><br><span class="line">&#123;</span><br><span class="line">char name[20]; //商品名</span><br><span class="line">int num;//数量</span><br><span class="line">char price[10];//价格-</span><br><span class="line">char date[8];  //编号</span><br><span class="line">struct Product* next;</span><br><span class="line">&#125;*pHead;</span><br><span class="line">//!=登录</span><br><span class="line"></span><br><span class="line">//声明函数</span><br><span class="line">void login(); //登陆界面 1.管理员登录 2.客户直接登录</span><br><span class="line">//!=管理员</span><br><span class="line">void adminPanel();            //管理员界面</span><br><span class="line">void addProduct_admin();      //添加商品</span><br><span class="line">void delProduct_admin();      //删除商品</span><br><span class="line">void modifyProduct_admin();   //修改商品</span><br><span class="line">void showProduct_admin();     //显示商品</span><br><span class="line"></span><br><span class="line">//!=顾客</span><br><span class="line">void customerPanel();                            //用户界面</span><br><span class="line">void addProduct_customer(struct Product* produ); //添加商品</span><br><span class="line">void showProduct_customer();                     //显示商品</span><br><span class="line">void showShopCart();                             //显示购物车</span><br><span class="line">void manageShopCart(struct Product* produ);      //管理购物车</span><br><span class="line">void cleanShopCart(struct Product* produ);       //结账</span><br><span class="line">void shopCart();                                 //购物车</span><br><span class="line">void pay(struct Product* produ);                 //查看购物车</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">//!=通用</span><br><span class="line">void readFile();  //读入</span><br><span class="line">void writeFile(); //写入</span><br><span class="line">void modifyFile();//保存</span><br><span class="line">struct Product* _productIsExist(char name[], struct Product* rhead); //查找货物是否存在</span><br><span class="line"></span><br><span class="line">//!=登录</span><br><span class="line">//布尔型（bool）变量的值只有 真 （true) 和假 （false）</span><br><span class="line">//函数声明，返回类型为布尔值</span><br><span class="line">bool verify()</span><br><span class="line">&#123;</span><br><span class="line">char account[20], password[20];</span><br><span class="line">printf(&quot;请输入账号:\t&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;account);</span><br><span class="line">printf(&quot;请输入密码:\t&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;password);</span><br><span class="line">if (strcmp(ADMINACCOUT, account) == 0 &amp;&amp; strcmp(ADMINPWD, password) == 0)    //两个字符串进行比较根据ACSII码的值</span><br><span class="line">&#123;</span><br><span class="line">return true;</span><br><span class="line">&#125;</span><br><span class="line">else</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;密码错误！\n&quot;);</span><br><span class="line">return false;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//登录</span><br><span class="line">void login()</span><br><span class="line">&#123;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">//清屏操作</span><br><span class="line"></span><br><span class="line">printf(&quot;----------欢迎使用购物车系统----------\n\n&quot;);</span><br><span class="line"></span><br><span class="line">printf(&quot;1-------管理员\n&quot;);</span><br><span class="line">printf(&quot;2-------购物用户\n&quot;);</span><br><span class="line">//==选择登录</span><br><span class="line">printf(&quot;请输入您的选项:\n&quot;);</span><br><span class="line">char key;</span><br><span class="line">while (1) </span><br><span class="line">&#123;</span><br><span class="line">key = _getch();  //获取一个字符</span><br><span class="line">if (key == &#x27;1&#x27;)</span><br><span class="line">&#123;</span><br><span class="line">if (!verify()) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;账号或密码错误&quot;);</span><br><span class="line">login();</span><br><span class="line">&#125;</span><br><span class="line">adminPanel();</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;2&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">customerPanel();</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">//!=管理员</span><br><span class="line">void adminPanel()</span><br><span class="line">&#123;</span><br><span class="line">char key;</span><br><span class="line">//1.添加货物</span><br><span class="line">//2.修改货物</span><br><span class="line">//3.删除货物</span><br><span class="line">//4.显示货物</span><br><span class="line">//5.返回主界面</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;\n管理员登录成功，上班快乐！\n&quot;);</span><br><span class="line">printf(&quot;----------------------------\n&quot;);</span><br><span class="line">printf(&quot;1 ----- 增加商品条目\n&quot;);</span><br><span class="line">printf(&quot;2 ----- 删除商品条目\n&quot;);</span><br><span class="line">printf(&quot;3 ----- 修改商品条目\n&quot;);</span><br><span class="line">printf(&quot;4 ----- 显示商品条目\n&quot;);</span><br><span class="line">printf(&quot;5 ----- 返回主界面\n&quot;);</span><br><span class="line">while (1)</span><br><span class="line">&#123;</span><br><span class="line">             //输入一个字符，它把你输入的字符赋值给变量key</span><br><span class="line">printf(&quot;请选择功能编号：&quot;);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;key);</span><br><span class="line">switch (key)</span><br><span class="line">&#123;</span><br><span class="line">case 1:</span><br><span class="line">addProduct_admin();</span><br><span class="line">break;;</span><br><span class="line">case 2:</span><br><span class="line">delProduct_admin();</span><br><span class="line">break;</span><br><span class="line">case 3:</span><br><span class="line">modifyProduct_admin();</span><br><span class="line">break;</span><br><span class="line">case 4:</span><br><span class="line">showProduct_admin();</span><br><span class="line">break;</span><br><span class="line">case 5:</span><br><span class="line">login();</span><br><span class="line">break;</span><br><span class="line">default:</span><br><span class="line">printf(&quot;选项不存在！\n&quot;);</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">adminPanel();</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//添加商品</span><br><span class="line">void addProduct_admin() </span><br><span class="line">&#123;</span><br><span class="line">//因为物品要更新所以每更新一次读一次</span><br><span class="line">readFile();</span><br><span class="line">if (pHead == NULL) </span><br><span class="line">&#123;</span><br><span class="line">MessageBox(NULL, &quot;头节点为空&quot;, &quot;确认&quot;, MB_OK); //MessageBox显示一个模态对话框   // MB_OK 是</span><br><span class="line">exit(0);                    //正常退出</span><br><span class="line">&#125;</span><br><span class="line">struct Product* rhead = pHead;</span><br><span class="line">struct Product* newNode = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">struct Product* _rhead = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">_rhead-&gt;next = NULL;</span><br><span class="line"></span><br><span class="line">_rhead = pHead;</span><br><span class="line">//全局链表的遍历</span><br><span class="line">newNode-&gt;next = NULL;</span><br><span class="line">while (rhead-&gt;next != NULL)</span><br><span class="line">&#123;</span><br><span class="line">rhead = rhead-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">struct Product* lastNode = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">lastNode-&gt;next = NULL;</span><br><span class="line"></span><br><span class="line">lastNode = rhead;</span><br><span class="line">printf(&quot;添加货物:\n&quot;);</span><br><span class="line">printf(&quot;请输入编号\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;newNode-&gt;date);</span><br><span class="line">printf(&quot;请输入货物名\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;newNode-&gt;name);</span><br><span class="line"></span><br><span class="line">struct Product* oldNode = _productIsExist(newNode-&gt;name, _rhead);</span><br><span class="line">if (oldNode != NULL) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;货物已存在,请改变该货物的其它信息\n&quot;);</span><br><span class="line">newNode = oldNode;</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;请输入数量\n&quot;);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;newNode-&gt;num);</span><br><span class="line">printf(&quot;请输入单价\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;newNode-&gt;price);</span><br><span class="line">printf(&quot;正在添加...&quot;);</span><br><span class="line">if (oldNode != NULL)</span><br><span class="line">&#123;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line">else</span><br><span class="line">&#123;</span><br><span class="line">lastNode-&gt;next = newNode; //添加到尾节点</span><br><span class="line">&#125;</span><br><span class="line">writeFile();</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//删除商品</span><br><span class="line">void delProduct_admin()</span><br><span class="line">&#123;</span><br><span class="line">showProduct_admin();</span><br><span class="line">char name[20];</span><br><span class="line">readFile();</span><br><span class="line">if (pHead == NULL) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;头节点加载失败&quot;);</span><br><span class="line">exit(0);</span><br><span class="line">&#125;</span><br><span class="line">struct Product* rhead = pHead;</span><br><span class="line">printf(&quot;请输入你需要删除的货物名:\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;name);</span><br><span class="line">struct Product* target = _productIsExist(name, rhead);</span><br><span class="line">if (rhead != NULL &amp;&amp; target != NULL) </span><br><span class="line">&#123;</span><br><span class="line">int num = target-&gt;num;</span><br><span class="line">int delNum = 0;</span><br><span class="line">printf(&quot;货物名:%s数量:%d\n&quot;, target-&gt;name, target-&gt;num);</span><br><span class="line">printf(&quot;请输入删除的数量\n&quot;);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;delNum);</span><br><span class="line">target-&gt;num -= delNum;</span><br><span class="line">if (target-&gt;num &lt; 0)</span><br><span class="line">target-&gt;num = 0;</span><br><span class="line">//Sleep(2000);</span><br><span class="line">printf(&quot;货物:%s数量:%d\n&quot;, target-&gt;name, target-&gt;num);</span><br><span class="line">printf(&quot;当货物为零时视为删除该货物&quot;);</span><br><span class="line">writeFile();</span><br><span class="line">&#125;</span><br><span class="line">else </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;您查找的货物不存在!&quot;);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//修改商品</span><br><span class="line">void modifyProduct_admin() </span><br><span class="line">&#123;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">showProduct_admin();</span><br><span class="line">readFile();</span><br><span class="line">char key = &#x27;0&#x27;;</span><br><span class="line">char name[20];</span><br><span class="line">char tempStr[20];</span><br><span class="line">int tempNum;</span><br><span class="line">if (pHead == NULL) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;头节点为空\n&quot;);</span><br><span class="line">&#125;</span><br><span class="line">struct Product* rhead = pHead;</span><br><span class="line">printf(&quot;请输入修改的商品的名字:\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;name);</span><br><span class="line">struct Product* target = _productIsExist(name, rhead);</span><br><span class="line">if (target != NULL)</span><br><span class="line">&#123;</span><br><span class="line">while (true) </span><br><span class="line">&#123;</span><br><span class="line">//system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;请选择需要修改的内容:\n&quot;);</span><br><span class="line">printf(&quot;1-----编号\n&quot;);</span><br><span class="line">printf(&quot;2-----商品名\n&quot;);</span><br><span class="line">printf(&quot;3-----数量\n&quot;);</span><br><span class="line">printf(&quot;4-----单价\n&quot;);</span><br><span class="line">printf(&quot;5-----保存修改\n&quot;);</span><br><span class="line">printf(&quot;6-----返回上一级\n&quot;);</span><br><span class="line">printf(&quot;9-----返回菜单\n&quot;);</span><br><span class="line"></span><br><span class="line">key = _getch();</span><br><span class="line">if (key == &#x27;1&#x27;)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请输入新的编号\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;tempStr);</span><br><span class="line">strcpy(target-&gt;date, tempStr);</span><br><span class="line">printf(&quot;修改成功&quot;);</span><br><span class="line">Sleep(1000);</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;2&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请输入新的名字\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;tempStr);</span><br><span class="line">strcpy(target-&gt;name, tempStr);</span><br><span class="line">printf(&quot;修改成功&quot;);</span><br><span class="line">Sleep(1000);                   //退出运行</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;3&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请输入新的数量\n&quot;);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;tempNum);</span><br><span class="line">target-&gt;num = tempNum;</span><br><span class="line">printf(&quot;修改成功&quot;);</span><br><span class="line">Sleep(1000);</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;4&#x27;)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请输入新的单价\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, &amp;tempStr);</span><br><span class="line">strcpy(target-&gt;price, tempStr);</span><br><span class="line">printf(&quot;修改成功&quot;);</span><br><span class="line">Sleep(1000);</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">if (key == &#x27;5&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">writeFile();</span><br><span class="line">printf(&quot;写入成功&quot;);</span><br><span class="line">Sleep(1000);</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;6&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">modifyProduct_admin();</span><br><span class="line">&#125;</span><br><span class="line">if (key == &#x27;9&#x27;) </span><br><span class="line">&#123;</span><br><span class="line">adminPanel();</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">else </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;商品没找到&quot;);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">//显示商品</span><br><span class="line">void showProduct_admin()</span><br><span class="line">&#123;</span><br><span class="line">readFile();</span><br><span class="line">struct Product* temp = pHead;</span><br><span class="line">//清屏操作</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;---------------商品条目如下------------------\n&quot;);</span><br><span class="line">printf(&quot;编号商品名数量单价\n&quot;);</span><br><span class="line">while (temp != NULL) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;%s%s%d%s\n&quot;, temp-&gt;date, temp-&gt;name, temp-&gt;num, temp-&gt;price);</span><br><span class="line">temp = temp-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;按任意键退出\n&quot;);</span><br><span class="line">_getch();</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//!=顾客</span><br><span class="line">void customerPanel() </span><br><span class="line">&#123;</span><br><span class="line">//1.增购货物</span><br><span class="line">//2.修改货物</span><br><span class="line">//3.删除货物</span><br><span class="line">//4.显示货物</span><br><span class="line">//5.写入</span><br><span class="line">struct Product* shopCart;</span><br><span class="line">shopCart = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">shopCart-&gt;next = NULL;</span><br><span class="line">strcpy(shopCart-&gt;name, &quot;购物车&quot;);</span><br><span class="line">strcpy(shopCart-&gt;price, &quot;0&quot;);</span><br><span class="line">strcpy(shopCart-&gt;name, &quot;now&quot;);</span><br><span class="line">shopCart-&gt;num = 0;</span><br><span class="line">//清屏操作</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;-----欢迎来到购物商城！-----\n&quot;);</span><br><span class="line">printf(&quot;----------------------------\n&quot;);</span><br><span class="line">printf(&quot;1.---------购物\n&quot;);</span><br><span class="line">printf(&quot;2.---------删除购物车\n&quot;);</span><br><span class="line">printf(&quot;3.---------查看购物车\n&quot;);</span><br><span class="line">printf(&quot;4.---------结账\n&quot;);</span><br><span class="line">printf(&quot;5.---------离开\n&quot;);</span><br><span class="line">printf(&quot;----------------------------\n&quot;);</span><br><span class="line">int key;</span><br><span class="line">while (1) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请选择您的操作:&quot;);</span><br><span class="line">fflush(stdin);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;key);</span><br><span class="line">switch (key)</span><br><span class="line">&#123;</span><br><span class="line">case 1:</span><br><span class="line">addProduct_customer(shopCart);</span><br><span class="line">break;</span><br><span class="line">case 2:</span><br><span class="line">manageShopCart(shopCart);</span><br><span class="line">break;</span><br><span class="line">case 3:</span><br><span class="line">pay(shopCart);</span><br><span class="line">break;</span><br><span class="line">case 4:</span><br><span class="line">cleanShopCart(shopCart);</span><br><span class="line">break;</span><br><span class="line">case 5:</span><br><span class="line">login();</span><br><span class="line">break;</span><br><span class="line">default:</span><br><span class="line">printf(&quot;选项不存在！\n&quot;);</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;-----欢迎来到购物商城！-----\n&quot;);</span><br><span class="line">printf(&quot;-------------------------------\n&quot;);</span><br><span class="line">printf(&quot;1.---------购物\n&quot;);</span><br><span class="line">printf(&quot;2.---------删除购物车\n&quot;);</span><br><span class="line">printf(&quot;3.---------查看购物车\n&quot;);</span><br><span class="line">printf(&quot;4.---------结账\n&quot;);</span><br><span class="line">printf(&quot;5.---------离开\n&quot;);</span><br><span class="line">printf(&quot;---------------------------\n&quot;);</span><br><span class="line">printf(&quot;\n&quot;);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">//添加商品</span><br><span class="line">void addProduct_customer(struct Product* produ) </span><br><span class="line">&#123;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">showProduct_customer();</span><br><span class="line">readFile();</span><br><span class="line">char name[40];</span><br><span class="line">char price[20];</span><br><span class="line">int num = 0;</span><br><span class="line">int index = 0;</span><br><span class="line">char key = &#x27;0&#x27;;</span><br><span class="line">struct Product* rhead = pHead;</span><br><span class="line">struct Product* currNode = produ;</span><br><span class="line">while (currNode-&gt;next != NULL)</span><br><span class="line">&#123;</span><br><span class="line">currNode = currNode-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">printf(&quot;请选择您需要商品(输入商品名):\n&quot;);</span><br><span class="line">scanf(&quot;%s&quot;, name);</span><br><span class="line">while (rhead != NULL)</span><br><span class="line">&#123;</span><br><span class="line">if (strcmp(rhead-&gt;name, name) == 0)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;您选择了%s\n&quot;, rhead-&gt;name);</span><br><span class="line">printf(&quot;请输入您需要数量:\n&quot;);</span><br><span class="line">strcpy(price, rhead-&gt;price);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;num);</span><br><span class="line">if (rhead-&gt;num - num &lt; 0)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;您选择了全部\n&quot;);</span><br><span class="line">num = rhead-&gt;num;</span><br><span class="line">rhead-&gt;num = 0;</span><br><span class="line">&#125;</span><br><span class="line">//==加入购物车</span><br><span class="line">struct Product* newNode = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">strcpy(newNode-&gt;name, rhead-&gt;name);</span><br><span class="line">strcpy(newNode-&gt;price, price);</span><br><span class="line">newNode-&gt;num = num;</span><br><span class="line">newNode-&gt;next = NULL;</span><br><span class="line">currNode-&gt;next = newNode;</span><br><span class="line">currNode = currNode-&gt;next;</span><br><span class="line">printf(&quot;%s,数量%d,成功加入购物车!\n&quot;, currNode-&gt;name, currNode-&gt;num);</span><br><span class="line">index++;</span><br><span class="line">printf(&quot;是否继续购物?\n&quot;);</span><br><span class="line">printf(&quot; 1-继续 2-退出\n&quot;);</span><br><span class="line">key = _getch();</span><br><span class="line">if (key != &#x27;1&#x27;)</span><br><span class="line">break;</span><br><span class="line">addProduct_customer(produ);</span><br><span class="line">&#125;</span><br><span class="line">rhead = rhead-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">//printf(&quot;没有找到该商品!&quot;);</span><br><span class="line">_getch();</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//支付</span><br><span class="line">void pay(struct Product* produ)</span><br><span class="line">&#123;</span><br><span class="line">char key = 0;</span><br><span class="line">struct Product* tempProdu = produ;</span><br><span class="line">float total = 0.0;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;----------购物车----------\n&quot;);</span><br><span class="line">while (tempProdu != NULL)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;%s%d%s\n&quot;, tempProdu-&gt;name, tempProdu-&gt;num, tempProdu-&gt;price);</span><br><span class="line">total += tempProdu-&gt;num * atof(tempProdu-&gt;price);    //字符串转换成浮点数 +=</span><br><span class="line">tempProdu = tempProdu-&gt;next;                         //尾插法</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;---------------&gt;总计:%.2f\n&quot;, total);</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">writeFile();</span><br><span class="line">_getch();</span><br><span class="line">&#125;</span><br><span class="line">//</span><br><span class="line">void cleanShopCart(struct Product *produ)</span><br><span class="line">&#123;</span><br><span class="line">struct Product* tempProdu = produ;</span><br><span class="line">float total = 0.0;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">char name[20];</span><br><span class="line">char key = &#x27;0&#x27;;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;-----------购物车---------\n&quot;);</span><br><span class="line">printf(&quot;商品名数量单价\n&quot;);</span><br><span class="line">while (tempProdu != NULL)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;%s%d%s\n&quot;, tempProdu-&gt;name, tempProdu-&gt;num, tempProdu-&gt;price);</span><br><span class="line">tempProdu = tempProdu-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;--------------------------\n&quot;);</span><br><span class="line">printf(&quot;请输入你要结账了吗？\n&quot;);</span><br><span class="line">tempProdu = produ;</span><br><span class="line">printf(&quot;输入1-结账,2-返回\n&quot;);</span><br><span class="line">if (_getch() == &#x27;1&#x27;) </span><br><span class="line">&#123;</span><br><span class="line"></span><br><span class="line">tempProdu-&gt;next = NULL;</span><br><span class="line">tempProdu = NULL;</span><br><span class="line">free(tempProdu);</span><br><span class="line">printf(&quot;购买成功\n&quot;);</span><br><span class="line">_getch();</span><br><span class="line">printf(&quot;1-返回，2-退出\n&quot;);</span><br><span class="line">if (_getch() == &#x27;2&#x27;)</span><br><span class="line">exit(0);</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line">else </span><br><span class="line">&#123;</span><br><span class="line">writeFile();</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line">//显示商品</span><br><span class="line">void showProduct_customer()</span><br><span class="line">&#123;</span><br><span class="line">readFile();</span><br><span class="line">struct Product* temp = pHead;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;---------------------商品条目如下-------------------\n&quot;);</span><br><span class="line">printf(&quot;编号商品名数量单价\n&quot;);</span><br><span class="line">while (temp != NULL)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;%s%s%d%s\n&quot;,  temp-&gt;date, temp-&gt;name, temp-&gt;num, temp-&gt;price);</span><br><span class="line">temp = temp-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//删除商品</span><br><span class="line">void manageShopCart(struct Product* produ)</span><br><span class="line">&#123;</span><br><span class="line">showProduct_customer();</span><br><span class="line">struct Product* tempProdu = produ;</span><br><span class="line">char name[20];</span><br><span class="line">char key = &#x27;0&#x27;;</span><br><span class="line">int num;</span><br><span class="line">system(&quot;cls&quot;);</span><br><span class="line">printf(&quot;-----------购物车---------\n&quot;);</span><br><span class="line">printf(&quot;商品名数量单价\n&quot;);</span><br><span class="line">while (tempProdu != NULL) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;%s%d%s\n&quot;, tempProdu-&gt;name, tempProdu-&gt;num, tempProdu-&gt;price);</span><br><span class="line">tempProdu = tempProdu-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;--------------------------\n&quot;);</span><br><span class="line">printf(&quot;请输入你需要删除的物品名\n&quot;);</span><br><span class="line">tempProdu = produ;</span><br><span class="line">scanf(&quot;%s&quot;, &amp;name);</span><br><span class="line">while (tempProdu != NULL)</span><br><span class="line">&#123;</span><br><span class="line">if (strcmp(tempProdu-&gt;name, name) == 0) </span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;请输入删除的数量:\n&quot;);</span><br><span class="line">scanf(&quot;%d&quot;, &amp;num);</span><br><span class="line">if (tempProdu-&gt;num - num &lt; 0)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;你删除了这种商品！\n&quot;);</span><br><span class="line">tempProdu-&gt;num = 0;</span><br><span class="line">&#125;</span><br><span class="line">else</span><br><span class="line">&#123;</span><br><span class="line">tempProdu-&gt;num -= num;</span><br><span class="line">printf(&quot;%s还剩%d个商品&quot;, tempProdu-&gt;name, tempProdu-&gt;num);</span><br><span class="line">&#125;</span><br><span class="line">printf(&quot;是否继续删除?\n&quot;);</span><br><span class="line">printf(&quot;1-继续 2-取消&quot;);</span><br><span class="line">key = _getch();</span><br><span class="line">if (key == &#x27;1&#x27;)</span><br><span class="line">manageShopCart(produ);</span><br><span class="line">else</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line">tempProdu = tempProdu-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">//!==通用</span><br><span class="line">void readFile()</span><br><span class="line">&#123;</span><br><span class="line">&#123;</span><br><span class="line">struct Product* qe;</span><br><span class="line">struct Product* qt;</span><br><span class="line">FILE* file;</span><br><span class="line">pHead = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">pHead-&gt;next = NULL;</span><br><span class="line">file = fopen(FILENAME, &quot;a+&quot;);//打开已存在的文件时，光标位于文件尾，文件可读，可写读数据时，光标会回到开头</span><br><span class="line">if (file == NULL)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;指定文件不能打开\n&quot;);</span><br><span class="line">exit(1);</span><br><span class="line">&#125;</span><br><span class="line">if (file != NULL)</span><br><span class="line">&#123;</span><br><span class="line">char ch = fgetc(file);</span><br><span class="line">if (ch == EOF)</span><br><span class="line">&#123;</span><br><span class="line">printf(&quot;文件为空！\n&quot;);</span><br><span class="line">//===初始化====</span><br><span class="line">strcpy(pHead-&gt;name, &quot;0&quot;);</span><br><span class="line">pHead-&gt;num = 0;</span><br><span class="line">strcpy(pHead-&gt;date, &quot;0001&quot;);</span><br><span class="line">strcpy(pHead-&gt;price, &quot;0.0&quot;);</span><br><span class="line">//====</span><br><span class="line">return;</span><br><span class="line">&#125;</span><br><span class="line">rewind(file);</span><br><span class="line">if (file != NULL)</span><br><span class="line">&#123;</span><br><span class="line">qe = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">qe-&gt;next = NULL;</span><br><span class="line">pHead = NULL;</span><br><span class="line">while (!feof(file))</span><br><span class="line">&#123;</span><br><span class="line">qt = (struct Product*)malloc(sizeof(struct Product));</span><br><span class="line">qt-&gt;next = NULL;</span><br><span class="line">fscanf(file, &quot;%s\t%d\t%s\t%s\n&quot;, &amp;qt-&gt;name, &amp;qt-&gt;num, &amp;qt-&gt;date, &amp;qt-&gt;price);</span><br><span class="line">qe-&gt;next = qt;</span><br><span class="line">qe = qe-&gt;next;</span><br><span class="line">if (pHead == NULL)</span><br><span class="line">pHead = qe;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">&#125;</span><br><span class="line">fclose(file);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line">//写入信息</span><br><span class="line">void writeFile() </span><br><span class="line">&#123;</span><br><span class="line">FILE* file;</span><br><span class="line">file = fopen(FILENAME, &quot;w+&quot;);//打开可读写文件，若文件存在则文件长度清为零，即该文件内容会消失。若文件不存在则建立百该文件。</span><br><span class="line">if (file == NULL) </span><br><span class="line">&#123;</span><br><span class="line">MessageBox(NULL, &quot;文件写入异常&quot;, &quot;确认&quot;, MB_OK);//它会产生一个对话框。默认，“确定”</span><br><span class="line">exit(0);</span><br><span class="line">&#125;</span><br><span class="line">if (pHead == NULL) </span><br><span class="line">&#123;</span><br><span class="line">readFile();</span><br><span class="line">&#125;</span><br><span class="line">struct Product* temp = pHead;</span><br><span class="line">while (temp != NULL)</span><br><span class="line">&#123;</span><br><span class="line">if (temp-&gt;num == 0) </span><br><span class="line">&#123;</span><br><span class="line">temp = temp-&gt;next;</span><br><span class="line">if (temp == NULL)</span><br><span class="line">break;</span><br><span class="line">&#125;</span><br><span class="line">fprintf(file, &quot;%s\t%d\t%s\t%s\n&quot;, temp-&gt;name, temp-&gt;num, temp-&gt;date, temp-&gt;price);</span><br><span class="line">temp = temp-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">fclose(file);</span><br><span class="line">&#125;</span><br><span class="line">//链表节点</span><br><span class="line">struct Product* _productIsExist(char name[], struct Product* rhead)</span><br><span class="line">&#123;</span><br><span class="line">struct Product* _rhead = rhead;</span><br><span class="line">while (_rhead != NULL) </span><br><span class="line">&#123;</span><br><span class="line">if (strcmp(_rhead-&gt;name, name) == 0)</span><br><span class="line">&#123;</span><br><span class="line">return _rhead;</span><br><span class="line">&#125;</span><br><span class="line">_rhead = _rhead-&gt;next;</span><br><span class="line">&#125;</span><br><span class="line">return NULL;</span><br><span class="line">&#125;</span><br><span class="line">//主要函数</span><br><span class="line">int main() </span><br><span class="line">&#123;</span><br><span class="line">login();</span><br><span class="line">return 0;</span><br><span class="line">&#125;</span><br><span class="line"></span><br></pre></td></tr></table></figure>]]></content>
      
      
      
